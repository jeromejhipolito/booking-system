    "alerts": {
      "success": {
        "template": "Account created! Welcome, {firstName}.",
        "style": "green bg, green border"
      },
      "error": {
        "style": "red bg, red border",
        "fallback_message": "Registration failed."
      }
    }
  },
  "api_contract": {
    "endpoint": "POST http://localhost:3001/v1/auth/register",
    "auth_required": false,
    "rate_limit": { "limit": 5, "ttl_seconds": 60 },
    "request_payload": {
      "firstName": "string (parsed from full name, first word)",
      "lastName": "string (parsed from full name, remaining words or duplicate of full name if single word)",
      "email": "string",
      "password": "string",
      "role": "customer | provider"
    },
    "name_parsing_logic": "name.trim().split(' '); firstName = parts[0] || name; lastName = parts.slice(1).join(' ') || name",
    "server_validation": {
      "email": "@IsEmail()",
      "password": "@IsString(), @MinLength(8), @MaxLength(128)",
      "firstName": "@IsString(), @MinLength(1), @MaxLength(100)",
      "lastName": "@IsString(), @MinLength(1), @MaxLength(100)",
      "role": "@IsOptional(), @IsIn(['provider', 'customer'])"
    },
    "success_response": {
      "status": 200,
      "body": { "user": "object", "accessToken": "JWT", "refreshToken": "UUID" }
    },
    "error_responses": [
      { "status": 400, "condition": "validation failures", "body": { "message": "array of errors" } },
      { "status": 409, "condition": "email already registered", "body": { "message": "Email already registered" } },
      { "status": 429, "condition": "rate limit exceeded", "body": { "message": "ThrottlerException: Too Many Requests" } }
    ]
  },
  "post_registration": {
    "localStorage": {
      "token": "accessToken value",
      "user": "JSON.stringify(user)"
    },
    "redirect_delay_ms": 1000,
    "redirect_customer": "/services",
    "redirect_provider": "/onboarding"
  },
  "accessibility_issues_found": [
