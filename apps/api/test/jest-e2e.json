{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@booking/shared-types(.*)$": "<rootDir>/../../packages/shared-types/src$1",
    "^@booking/shared-constants(.*)$": "<rootDir>/../../packages/shared-constants/src$1",
    "^@booking/shared-utils(.*)$": "<rootDir>/../../packages/shared-utils/src$1"
  },
  "testTimeout": 30000
}
